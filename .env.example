# ========================================
# KHUROSON MES - CONFIGURATION TEMPLATE
# ========================================

# === PROJECT ===
PROJECT_NAME="Khuroson MES"
VERSION="2.0.0"
DEBUG=false

# === DATABASE (component parts) ===
# Разбиваем на компоненты для гибкости и переиспользования
DB_USER="mes_user"
DB_PASSWORD="your_password"
DB_HOST="localhost"
DB_PORT=5432
DB_NAME="khuroson_mes"

# === DATABASE POOL (production настройки) ===
# DB_POOL_SIZE: кол-во соединений в пуле для asyncpg
# DB_MAX_OVERFLOW: доп. соединения сверх pool_size когда нужно
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10
DB_ECHO=false

# === LOGGING ===
LOG_LEVEL="INFO"

# === CORS ===
# Для production: CORS_ORIGINS="http://localhost:3000,https://yourfrontend.com"
CORS_ORIGINS="*"

# === SECURITY ===
SECRET_KEY="your-secret-key-change-in-production"
ALGORITHM="HS256"
