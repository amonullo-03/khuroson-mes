# ========================================
# KHUROSON MES - CONFIGURATION TEMPLATE
# ========================================
# Скопируйте этот файл в .env и заполните реальными значениями
# $ cp .env.example .env

# === PROJECT ===
PROJECT_NAME="Khuroson MES"
VERSION="2.0.0"
DEBUG=false

# === DATABASE (component parts) ===
# Разбиваем на компоненты для гибкости и переиспользования
# Например, можно использовать разные DB_HOST для prod и dev
DB_USER="mes_user"
DB_PASSWORD="your_secure_password_here"
DB_HOST="localhost"
DB_PORT=5432
DB_NAME="khuroson_mes"

# === DATABASE POOL (production настройки) ===
# DB_POOL_SIZE: кол-во постоянных соединений в пуле для asyncpg
# Рекомендация: для dev=10, для prod=20-50 в зависимости от нагрузки
DB_POOL_SIZE=20

# DB_MAX_OVERFLOW: дополнительные соединения когда пул перегружен
# Примечание: для asyncpg это не работает так же как для SQLAlchemy sync
DB_MAX_OVERFLOW=10

# DB_ECHO: логирование всех SQL запросов в консоль (только для разработки!)
# production: false
DB_ECHO=false

# === LOGGING ===
# Уровни: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL="INFO"

# === CORS ===
# Для разработки: CORS_ORIGINS="*"
# Для production: CORS_ORIGINS="https://yourfrontend.com,https://app.example.com"
CORS_ORIGINS="*"

# === API ===
API_V1_PREFIX="/api/v1"

# === SECURITY ===
# SECRET_KEY: используется для JWT токенов и других криптографических операций
# ОБЯЗАТЕЛЬНО измените это значение на production!
# Генерируйте: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY="your-secret-key-change-in-production"
ALGORITHM="HS256"
